# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=underwriting
POSTGRES_PASSWORD=underwriting
POSTGRES_DB=underwriting

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# LLM provider — choose one: groq | openai | ollama | vertex
LLM_PROVIDER=groq

# Groq (recommended for free-tier demos — https://console.groq.com)
GROQ_API_KEY=                    # primary key name
GROQ_KEY=                        # alias — either GROQ_API_KEY or GROQ_KEY is accepted
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=

# Ollama (optional, local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Vertex AI / Gemini (optional, requires GCP project)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash

# App
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CONFIDENCE_THRESHOLD=0.65
UPLOAD_DIR=/app/uploads
DATA_DIR=/app/data

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
